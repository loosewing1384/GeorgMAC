        <!-- ↓↓↓↓↓↓↓↓↓↓↓↓↓↓↓↓↓↓↓↓↓↓↓↓↓↓↓↓↓↓↓↓↓↓↓↓↓ -->
        <!-- ↓↓↓↓↓↓↓↓↓↓↓↓↓↓↓↓↓↓↓↓↓↓↓↓↓↓↓↓↓↓↓↓↓↓↓↓↓ -->
        <!-- ↓↓↓↓↓↓↓↓↓↓↓↓↓↓↓↓↓↓↓↓↓↓↓↓↓↓↓↓↓↓↓↓↓↓↓↓↓ -->
        <!-- inicio fragmento vvv. 4.511-515 -->
        <l resp="#PF" xml:id="zj1_zzt_r2c" source="#d1e1706" corresp="511" cert="high">
          <seg cert="high">
            just as a nightingale
          </seg>
          <seg cert="medium" ana="#sint" source="#dds_sjf_p2c">
            will sorrow
          </seg>
          <seg cert="high">
            under poplar shade
          </seg>
        </l>
        
        
        <l resp="#PF" xml:id="gpk_115_r2c" source="#d1e1709" corresp="512" cert="high">
          <seg cert="high" source="#r4f_zjf_p2c">
            for her lost brood which some brute 
            ploughboy spotted
          </seg>
        </l>
        
        
        <l resp="#PF" xml:id="a34_115_r2c" source="#d1e1712" corresp="513" cert="high">
          <seg cert="high" source="#szr_2pf_p2c">
            and pilfered from the nest, 
            though it was not yet fledged.
          </seg>
        </l>
        
        
        <l resp="#PF" xml:id="f2t_115_r2c" source="#d1e1715" corresp="514" cert="medium">
          <seg cert="high">
            That
          </seg>
          <seg ana="#add #rep" subana="#NP" cert="medium">
            bird
          </seg> 
          <seg ana="#add" subana="#AdvP" cert="low">
            still
          </seg> 
          <seg cert="high" source="#jl3_g4f_p2c #u3j_bpf_p2c">
            weeps by night and,
            perched in a tree, repeats
          </seg>
        </l>
        
        
        <l resp="#PF" xml:id="ocx_115_r2c" source="#d1e1719" corresp="515" cert="high">
          <seg orig="miserabile carmen" cert="high">
            her plaintive keen,
          </seg> 
          <seg orig="implet" cert="high" source="#qd2_wkf_p2c">
            filling
          </seg>
          <seg xml:id="ztb_f55_r2c" orig="late loca... " synch="#wws_l55_r2c" cert="high" source="#uxb_ykf_p2c">
            far and wide
          </seg>
          <seg ana="#sem" orig="maestis questibus" cert="high" source="#prg_w4f_p2c">
            with the ache of her heartbreak
          </seg>
        </l>
        <!-- fin fragmento  vv. 4.511-515 -->
        <!--  ↑↑↑↑↑↑↑↑↑↑↑↑↑↑↑↑↑↑↑↑↑↑↑↑↑↑↑↑↑↑↑↑↑↑↑↑ -->
