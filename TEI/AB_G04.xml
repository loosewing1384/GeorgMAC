        <!-- ↑↑↑↑↑↑↑↑↑↑↑↑↑↑↑↑↑↑↑↑↑↑↑↑↑↑↑↑↑↑↑↑↑↑↑↑↑ -->
        
        
        <!-- ↓↓↓↓↓↓↓↓↓↓↓↓↓↓↓↓↓↓↓↓↓↓↓↓↓↓↓↓↓↓↓↓↓↓↓↓↓ -->
        <!-- ↓↓↓↓↓↓↓↓↓↓↓↓↓↓↓↓↓↓↓↓↓↓↓↓↓↓↓↓↓↓↓↓↓↓↓↓↓ -->
        <!-- ↓↓↓↓↓↓↓↓↓↓↓↓↓↓↓↓↓↓↓↓↓↓↓↓↓↓↓↓↓↓↓↓↓↓↓↓↓ -->
        <!-- inicio fragmento vvv. 4.511-515 -->       
        <l resp="#AB" xml:id="wvj_me5_hnn" source="#d1e1706" corresp="511" cert="high">
          <seg cert="high" source="#dds_sjf_p2c">tal la afligida Filomela, que a la sombra de un álamo</seg>
        </l>
        
        
        <l resp="#AB" xml:id="aam_lxf_el2" source="#d1e1709" corresp="512" cert="high">
          <seg cert="high">lamenta los perdidos hijos que el labriego </seg>
          <seg ana="#sem" orig="durus" cert="medium" source="#r4f_zjf_p2c">implacable</seg>
        </l>
        
        
        <l resp="#AB" xml:id="jwd_to4_w4t" source="#d1e1712" corresp="513" cert="high">
          <seg ana="#sem" orig="observans" source="#szr_2pf_p2c" cert="medium">al acecho del nido</seg>
          <seg cert="high"> arrancó implumes; y ella</seg>
          <seg ana="#sint" orig="at illa [flet]" cert="high">los llora</seg>
        </l>
        
        
        <l resp="#AB" xml:id="yq4_s43_xec" source="#d1e1715" corresp="514" cert="high">
          <seg cert="high" source="#jl3_g4f_p2c #u3j_bpf_p2c">toda la noche y, en su rama posada, el triste canto</seg>
        </l>
        
        
        <l resp="#AB" xml:id="ldz_iez_0sd" source="#d1e1719" corresp="515" cert="high">
          <seg cert="high" source="#qd2_wkf_p2c">renueva y con </seg>
          <seg ana="#sem" orig="maestis questibus" cert="medium" source="#prg_w4f_p2c">amargas quejas</seg>
          <seg cert="high" source="#uxb_ykf_p2c"> llena</seg>
          <seg ana="#semd" orig="loca" cert="medium">el bosque</seg>
          <seg cert="high"> a lo lejos.</seg>
        </l>
        <!-- fin fragmento  vv. 4.511-515 -->
