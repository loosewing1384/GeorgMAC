        <!-- ↑↑↑↑↑↑↑↑↑↑↑↑↑↑↑↑↑↑↑↑↑↑↑↑↑↑↑↑↑↑↑↑↑↑↑↑↑ -->
        
        
        
        <!-- ↓↓↓↓↓↓↓↓↓↓↓↓↓↓↓↓↓↓↓↓↓↓↓↓↓↓↓↓↓↓↓↓↓↓↓↓↓ -->
        <!-- ↓↓↓↓↓↓↓↓↓↓↓↓↓↓↓↓↓↓↓↓↓↓↓↓↓↓↓↓↓↓↓↓↓↓↓↓↓ -->
        <!-- ↓↓↓↓↓↓↓↓↓↓↓↓↓↓↓↓↓↓↓↓↓↓↓↓↓↓↓↓↓↓↓↓↓↓↓↓↓ -->
        <!-- inicio fragmento vvv. 4.511-515 -->
        <l resp="#RBN" xml:id="kjs_4y5_r2c" source="#d1e1706" corresp="511" cert="high">
          <seg cert="high">
            Como
          </seg> 
          <seg cert="high">
            Filomena,
          </seg> 
          <seg cert="high" source="#dds_sjf_p2c">
            afligida bajo la sombra de un álamo,
          </seg>
        </l>
        
        
        <l resp="#RBN" xml:id="n4x_4y5_r2c" source="#d1e1709" corresp="512" cert="high">
          <seg cert="high" source="#r4f_zjf_p2c">
            lamenta sus hijos perdidos 
            a los que el duro labriego,
          </seg>
        </l>
        
        
        <l resp="#RBN" xml:id="njc_py5_r2c" source="#d1e1712" corresp="513" cert="high">
          <seg ana="#sem #sint" cert="high" source="#szr_2pf_p2c">
            acechando,
          </seg>
          <seg cert="high">
            sustrajo implumes del nido.
            Mas ella
          </seg>
        </l>
        
        
        <l resp="#RBN" xml:id="lmg_py5_r2c" source="#d1e1715" corresp="514" cert="high">
          <seg cert="high" source="#jl3_g4f_p2c">
            llora en la noche, 
            y el lúgubre canto posada en la rama
          </seg>
        </l>
        
        
        <l resp="#RBN" xml:id="y5t_py5_r2c" source="#d1e1719" corresp="515" cert="high">
          <seg cert="high" source="#u3j_bpf_p2c #prg_w4f_p2c #qd2_wkf_p2c">
            renueva, 
            y con tristes quejas llena
          </seg>
          <seg ana="#sint" orig="loca" cert="medium" source="#uxb_ykf_p2c">
            el lugar
          </seg>
          <seg cert="high">
            latamente.
          </seg>
        </l>
        <!-- fin fragmento  vv. 4.511-515 -->
